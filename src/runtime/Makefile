# Chrysopolis: beam_server protection domain (Plan B).
#
# beam_server links the thin Microkit<->ERTS glue (main.c + bring-up shims)
# against the LionsOS POSIX libc (libc.a) and libmicrokit, mirroring the
# LionsOS reference examples' link line (ld.lld + microkit.ld + -lc). The
# sDDF serial/timer queue ops are header-inline, so no extra sDDF archive is
# needed here; the driver PDs are separate ELFs built by nix/refstack.mk.
#
# Variables are supplied by the Nix derivation:
#   BOARD_DIR    Microkit board dir ($MICROKIT_SDK/board/<board>/<config>)
#   LIONS_LIBC   lions-stack output (provides lib/libc.a and include/)
#   SDDF         sDDF source tree (headers)
#   LIONSOS_SRC  LionsOS source tree (lions/ headers)

BOARD_DIR   ?= $(error set BOARD_DIR to $$MICROKIT_SDK/board/<board>/<config>)
LIONS_LIBC  ?= $(error set LIONS_LIBC to the lions-stack output)
SDDF        ?= $(error set SDDF to the sDDF source tree)
LIONSOS_SRC ?= $(error set LIONSOS_SRC to the lionsos source tree)

CC     ?= clang
LD     ?= ld.lld
TARGET ?= aarch64-none-elf

# -I. finds libmicrokitco_opts.h (next to process.c); LIONS_LIBC/include has
# libmicrokitco.h + libhostedqueue/.
BASE_CFLAGS := -target $(TARGET) -mcpu=cortex-a53 -mstrict-align \
               -ffreestanding -g -O2 -Wall \
               -I. \
               -I$(BOARD_DIR)/include \
               -I$(LIONS_LIBC)/include \
               -I$(SDDF)/include -I$(SDDF)/include/microkit \
               -I$(LIONSOS_SRC)/include

# Nix stdenv sets hardening CFLAGS we don't want for freestanding code.
override CFLAGS := $(BASE_CFLAGS)

# libmicrokitco.a is a relocatable object (ld -r); list it directly. It
# provides the cothread runtime process.c's pthread layer spawns onto.
LIBMKCO := $(LIONS_LIBC)/lib/libmicrokitco.a

LDFLAGS := -L$(BOARD_DIR)/lib -L$(LIONS_LIBC)/lib
LIBS    := -lmicrokit -Tmicrokit.ld -lc

UNITS := main bringup process memfs
OBJS  := $(UNITS:%=%.o)

.PHONY: all clean
all: beam_server.elf

%.o: %.c
	$(CC) $(CFLAGS) -c $< -o $@

# microkit.ld + libmicrokit + libc.a, matching the LionsOS example link.
# dontStrip in Nix keeps the symbol table so the Microkit tool can patch
# beam_heap_start (setvar_vaddr) and objcopy can update the config sections.
beam_server.elf: $(OBJS) $(LIBMKCO)
	$(LD) $(LDFLAGS) -o $@ $(OBJS) $(BOOT_DATA_OBJ) $(LIBMKCO) $(LIBS)

# beam_server with the static ERTS archive linked in (Phase 4+). The ERTS
# archives reference each other circularly, hence --start-group; -u erl_start
# forces the emulator entry live. ERTS resolves its libc against libc.a.
#
# liberts.a is built with the gcc cross, so it calls libgcc runtime helpers
# (the aarch64 outline-atomics __aarch64_* in particular) absent from the
# -nostdlib link. LIBGCC_DIR points at the cross gcc's libgcc.a; it joins the
# archive group so those leaf helpers resolve.
#
# BOOT_DATA_OBJ is generated by gen-boot-data.sh in the Nix build.
LIBERTS_DIR ?=
LIBGCC_DIR  ?=
BOOT_DATA_OBJ ?=
ERTS_ARCHIVES := liberts.a liberts_internal.a liberts_internal_r.a \
  libethread.a libz.a libzstd.a libepcre.a libryu.a micro-openssl.a

beam_test.elf: $(OBJS) $(LIBMKCO)
	$(LD) $(LDFLAGS) -L$(LIBGCC_DIR) -u erl_start -o $@ $(OBJS) $(BOOT_DATA_OBJ) $(LIBMKCO) \
	  --start-group $(addprefix $(LIBERTS_DIR)/,$(ERTS_ARCHIVES)) -lgcc --end-group \
	  $(LIBS)

clean:
	rm -f $(OBJS) beam_server.elf beam_test.elf
